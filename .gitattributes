# Normalize line endings to LF in the repo; checkout as-is on all platforms
* text=auto eol=lf

# Shell scripts must always be LF (bash breaks on CRLF)
*.sh text eol=lf

# Windows-specific — keep CRLF if any
*.bat text eol=crlf
*.cmd text eol=crlf

# Binaries — no line-ending conversion
*.png binary
*.jpg binary
*.gz binary
*.db binary
